# OpenAI
OPENAI_API_KEY=sk-...

# Gemini / Google
GEMINI_API_KEY=...          # 또는
GOOGLE_API_KEY=...

# AWS Bedrock (model_type: "anthropic")
AWS_ACCESS_KEY=...           # 또는 AWS_ACCESS_KEY_ID
AWS_SECRET_KEY=...           # 또는 AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1         # 또는 AWS_DEFAULT_REGION (기본값 us-east-1)

# GCP Vertex AI - Anthropic Claude (model_type: "vertex")
GOOGLE_CLOUD_PROJECT=...     # 또는 GCP_PROJECT_ID
VERTEX_REGION=us-east5       # 또는 GOOGLE_CLOUD_REGION (기본값 us-east5)

# GCP Vertex AI - OpenAI-compatible (model_type: "vertex_openai", Llama/Qwen/Mistral 등)
GOOGLE_CLOUD_PROJECT=...     # 동일
VERTEX_OAI_REGION=us-east5   # 기본값 us-east5

# Together AI (model_type: "together")
TOGETHER_API_KEY=...

# 선택: LLM 호출 로그 (설정 시 JSONL로 토큰/레이턴시 기록)
LLM_CALL_LOG=data/logs/llm_usage.jsonl